#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force screenshotbot .
mise cache clear
mise install screenshotbot@1.0.0

# Capture and display the output while also verifying it
output=$(mise exec "screenshotbot@1.0.0" -- "screenshotbot" --version)
echo "screenshotbot output: $output"

if echo "$output" | grep -q 'screenshotbot@1.0.0'; then
    echo "✓ Tests passed"
else
    echo "✗ Test failed: expected version screenshotbot@1.0.0"
    exit 1
fi
